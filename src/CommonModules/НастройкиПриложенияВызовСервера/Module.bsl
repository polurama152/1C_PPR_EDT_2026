
// Возвращает синоним конфигурации для заголовка окна.
//
// Возвращаемое значение:
//  Строка - представление конфигурации.
//
Функция ПредставлениеКонфигурации() Экспорт

	Возврат Метаданные.Представление();

КонецФункции

// Возвращает текст пояса времени: Europe/Moscow (UTC+03:00).
//
// Возвращаемое значение:
//  Строка - идентификатор пояса и смещение в формате UTC±ЧЧ:ММ.
//
Функция ТекстПоясаВремени() Экспорт

	ИдентификаторПояса = ЧасовойПоясСеанса();
	СмещениеМировое = СмещениеПоясаМировойФормат(ИдентификаторПояса);

	Возврат ИдентификаторПояса + " (" + СмещениеМировое + ")";

КонецФункции

// Возвращает смещение пояса в формате UTC+03:00.
//
// Параметры:
//  ИдентификаторПояса - Строка, Неопределено - идентификатор пояса; по умолчанию пояс сеанса.
//
// Возвращаемое значение:
//  Строка - смещение, например UTC+03:00.
//
Функция СмещениеПоясаМировойФормат(ИдентификаторПояса = Неопределено) Экспорт

	Если ИдентификаторПояса = Неопределено Тогда
		ИдентификаторПояса = ЧасовойПоясСеанса();
	КонецЕсли;

	СмещениеСекунды = СмещениеСтандартногоВремени(ИдентификаторПояса) + СмещениеЛетнегоВремени(ИдентификаторПояса);

	Если СмещениеСекунды >= 0 Тогда
		Знак = "+";
		АбсолютноеСмещение = СмещениеСекунды;
	Иначе
		Знак = "-";
		АбсолютноеСмещение = -СмещениеСекунды;
	КонецЕсли;

	Часы = Цел(АбсолютноеСмещение / 3600);
	Минуты = Цел((АбсолютноеСмещение % 3600) / 60);

	ЧасыСтрокой = Формат(Часы, "ЧЦ=2; ЧВН=; ЧГ=0");
	МинутыСтрокой = Формат(Минуты, "ЧЦ=2; ЧВН=; ЧГ=0");

	Возврат "UTC" + Знак + ЧасыСтрокой + ":" + МинутыСтрокой;

КонецФункции